<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Default log level -->
    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Suppress verbose Jedis internal logging -->
    <logger name="redis.clients.jedis" level="WARN" />

    <!-- Keep only essential demo messages at INFO level -->
    <logger name="com.redis.demo" level="INFO" />
</configuration>

