# Redis Endpoints for Active-Active failover
# Format: [username]:[password]@host:port
redis.endpoint.east=default:password@redis-east.example.com:6379
redis.endpoint.west=default:password@redis-west.example.com:6379

# For local testing:
#redis.endpoint.east=localhost:6379
#redis.endpoint.west=localhost:6379

# Writer Configuration
writer.interval.ms=1000
writer.key.prefix=latency

# Value size (total size including timestamp)
# Timestamp format: "millis.nanos_" = ~21 bytes
# Actual padding size = value.size - 21
value.size=500

# Metrics Configuration
metrics.interval.seconds=15

# Background Load Configuration
background.load.enabled=true
background.load.threads=14
background.load.read.write.ratio=10
# Sleep between operations in nanoseconds (100,000 ns = 0.1ms = ~10K ops/sec per thread)
background.load.sleep.nanos=100000

# TTL Configuration
key.ttl.seconds=300

# Connection Pool Configuration
redis.pool.max.total=500
redis.pool.max.idle=100
redis.pool.min.idle=20

# ================================================================================
# Failover Configuration (MultiDbClient)
# ================================================================================

# Circuit Breaker - Sliding window size in seconds
failover.circuit.breaker.sliding.window.size=2

# Circuit Breaker - Minimum number of failures before circuit breaker trips
failover.circuit.breaker.min.num.failures=1000

# Retry - Maximum number of retry attempts (including initial call)
failover.retry.max.attempts=3

# Failover - Delay in milliseconds between failover attempts
failover.delay.between.attempts=12000

# Failover - Retry failed commands during failover (true/false)
failover.retry.on.failover=true

# Failback - Check interval in milliseconds to detect recovery
failover.failback.check.interval=120000

# Health Check - Interval in milliseconds between health checks
failover.health.check.interval=1000

